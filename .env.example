ENVIRONMENT=development
API_BASE_URL=http://localhost:8000
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DATABASE_URL=postgresql://postgres:mypassword@localhost:5432/mydb
ALLOWED_ORIGINS=localhost:3000
LLM_PROVIDER=DEEPSEEK
LLM_MODEL=deepseek-v4-flash

# Shared API token. Required to call any HTTP route or open a socket.
# In ENVIRONMENT=development an empty value disables the check so local
# work isn't blocked.
API_TOKEN=
DEFAULT_TENANT_ID=fcbb503a-6e49-4e4c-ac58-fc232064513e

# Seconds to wait after a chat message for follow-up bursts before
# dispatching the workflow. Bursts inside the window are concatenated.
CHAT_COALESCE_WINDOW_SECONDS=2

# Upload limits for /agents/setup
MAX_UPLOAD_FILE_BYTES=20971520
MAX_UPLOAD_FILE_COUNT=10
ALLOWED_UPLOAD_SUFFIXES=.pdf,.docx,.doc,.txt,.md,.csv,.xlsx,.html,.htm,.json,.yaml,.yml

GARAGE_ENDPOINT=http://localhost:3900
GARAGE_REGION=garage
GARAGE_ACCESS_KEY_ID=
GARAGE_SECRET_ACCESS_KEY=
GARAGE_BUCKET=minibots

# Scheduling agent — Google Calendar sync (optional; leave empty to disable)
# GCAL_SERVICE_ACCOUNT_JSON: paste the full contents of the service account JSON file
GCAL_SERVICE_ACCOUNT_JSON=
GCAL_CALENDAR_ID=primary

# Business hours for slot recommendations (HH:MM, 24h, local time)
SCHEDULING_TIMEZONE=UTC
SCHEDULING_BUSINESS_START=09:00
SCHEDULING_BUSINESS_END=18:00
