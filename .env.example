ENVIRONMENT=development
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DATABASE_URL=postgresql://postgres:mypassword@localhost:5432/mydb
ALLOWED_ORIGINS=localhost:3000
LLM_PROVIDER=DEEPSEEK
LLM_MODEL=deepseek-v4-flash

# Shared API token. Required to call any HTTP route or open a socket.
# In ENVIRONMENT=development an empty value disables the check so local
# work isn't blocked.
API_TOKEN=
DEFAULT_TENANT_ID=fcbb503a-6e49-4e4c-ac58-fc232064513e

GARAGE_ENDPOINT=http://localhost:3900
GARAGE_REGION=garage
GARAGE_ACCESS_KEY_ID=
GARAGE_SECRET_ACCESS_KEY=
GARAGE_BUCKET=minibots
